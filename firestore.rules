rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to get user data
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isAdmin() {
      return hasRole('Admin');
    }

    function isManager() {
      return hasRole('Manager');
    }

    function isKolkata() {
      return hasRole('Field Staff (Kolkata)');
    }

    function isPortBlair() {
      return hasRole('Field Staff (Port Blair)');
    }

    // Collection Group rule for Shipments (Required for consolidated reports)
    // For external users, we restrict reading to only their shipments
    match /{path=**}/shipments/{shipmentId} {
      allow read: if isSignedIn() && (
        !hasRole('Consignee') && !hasRole('Consignor') || 
        (hasRole('Consignee') && get(/databases/$(database)/documents/consignments/$(path[1])).data.shipToName == getUserData().organizationName) ||
        (hasRole('Consignor') && get(/databases/$(database)/documents/consignments/$(path[1])).data.consignorName == getUserData().organizationName)
      );
    }

    // Consignments
    match /consignments/{consignmentId} {
      allow read: if isSignedIn() && (
        !hasRole('Consignee') && !hasRole('Consignor') || 
        (hasRole('Consignee') && resource.data.shipToName == getUserData().organizationName) ||
        (hasRole('Consignor') && resource.data.consignorName == getUserData().organizationName)
      );
      
      allow create: if isAdmin() || isManager();
      allow update: if isAdmin() || isManager();
      allow delete: if isAdmin();

      // Shipments subcollection
      match /shipments/{shipmentId} {
        allow create: if isAdmin() || isManager() || isKolkata();
        allow update: if isAdmin() || isManager() || isKolkata() || isPortBlair();
        allow delete: if isAdmin() || (isKolkata() && resource.data.status != 'Received (Port Blair)' && resource.data.status != 'Delivered');
      }
    }

    // Audit Logs
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }

    // User roles and profiles
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
    
    // Counters
    match /counters/{counterId} {
      allow read, write: if isAdmin() || isManager();
    }

    // Organizations
    match /organizations/{orgId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isManager();
    }
  }
}
